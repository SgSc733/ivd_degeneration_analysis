{
  "data": {
    "csv_path": "最终模型输入.csv",
    "id_col": "case_id_层级",
    "label_col": "pfirrmann",
    "classic_prefix": "classic_",
    "patient_id_from_id_col": true,
    "patient_id_sep": "_",
    "level_from_id_col": true,
    "level_sep": "_",
    "segment_levels": [
      "L3-L4",
      "L4-L5",
      "L5-S1"
    ],
    "add_segment_onehot": false,
    "pooling": {
      "stats": [
        "mean-d"
      ],
      "pyr_prefix": "PyRadiomics_",
      "deep_prefix": "DeepPCA_",
      "tensor_prefix": "TensorPCA_",
      "feature_types": [
        "classic"
      ],
      "out_prefix": "pool_"
    },
    "drop_cols": [],
    "mode": "dual_csv",
    "unperturbed_csv_path": "raw.csv",
    "perturbed_csv_path": "pert.csv",
    "keep_feature_patterns": []
  },
  "labels": {
    "xlsx_path": "pfirr_data.xlsx",
    "sheet_name": null,
    "patient_id_col": "序号",
    "level_to_col": {
      "L3-L4": "L34",
      "L4-L5": "L45",
      "L5-S1": "L5S1"
    },
    "on_missing": "error"
  },
  "cv": {
    "n_splits": 5
  },
  "preprocess": {
    "enabled": true
  },
  "weights": {
    "patient_balance": true,
    "class_weight": {
      "enabled": false,
      "gamma_w": 0.0,
      "w_max": 5.0
    }
  },
  "xgb": {
    "params": {
      "booster": "gbtree",
      "objective": "reg:squarederror",
      "max_depth": 3,
      "min_child_weight": 1,
      "gamma": 0.1,
      "subsample": 0.9,
      "colsample_bytree": 0.9,
      "eta": 0.05,
      "reg_lambda": 10.0,
      "reg_alpha": 0.0,
      "tree_method": "hist",
      "seed": 0
    },
    "num_boost_round": 5000,
    "early_stopping_rounds": 50,
    "eval_metric": "mae",
    "verbose_eval": 50
  },
  "coral": {
    "n_classes": 5,
    "fit": {
      "enabled": true,
      "use_sample_weight": false,
      "epochs": 2000,
      "lr": 0.01,
      "weight_decay": 0.0,
      "batch_size": 0,
      "init": "quantile",
      "seed": 0,
      "patience": 200
    },
    "selection": {
      "enabled": true,
      "metric": "mae",
      "candidates": {
        "strategy": "topk_reg",
        "topk": 50,
        "window": 80
      },
      "fit": {
        "enabled": true,
        "use_sample_weight": false,
        "epochs": 300,
        "lr": 0.02,
        "weight_decay": 0.0,
        "batch_size": 0,
        "init": "quantile",
        "seed": 0,
        "patience": 50
      },
      "refit_theta_final": true
    }
  },
  "ordinal": {
    "n_classes": 5,
    "decision_threshold": {
      "default": 0.5
    }
  },
  "figures": {
    "enabled": true,
    "explain_top_n": 20,
    "explain_max_points": 200
  },
  "explain": {
    "enabled": false,
    "fold": "best",
    "dpi": 300,
    "top_n": 20,
    "bins": 30,
    "smooth": false,
    "x_axis": "raw",
    "by_task": false
  },
  "output": {
    "base_dir": "outputs_xgb",
    "run_name": null
  },
  "feature_selection": {
    "enabled": true,
    "statistics_csv_path": "statistics.csv",
    "feature_types": ["classic","pyradiomics","deep","tensor"],
    "enable_pca": true,
    "pca_eta": 0.95,
    "pca_m_cap": 50,
    "icc_threshold": 0.6,
    "alpha_fdr": 0.05,
    "rho_min": 0.0,
    "dup_corr_threshold": 0.95,
    "enable_stability_selection": true,
    "enet_l1_ratio": 0.8,
    "enable_auto_lambda_cv": true,
    "lambda_value": 0.01,
    "lambda_cv_folds": 5,
    "lambda_cv_n_alphas": 100,
    "lambda_cv_epsilon": 0.01,
    "lambda_cv_use_1se": false,
    "enable_lambda_size_tuning": false,
    "bootstrap_B": 50,
    "stability_delta": 0.0001,
    "stability_tau": 0.3,
    "k_max": 100,
    "deep_feature_prefixes": [
      "Deep_"
    ],
    "tensor_feature_prefixes": [
      "Tucker_",
      "Tensor_",
      "tensor_",
      "TENSOR_"
    ],
    "force_include_features": [
      "classic_dhi_dhi",
      "classic_dhi_disc_height",
      "classic_t2si_si_ratio",
      "classic_t2si_roi_si",
      "classic_t2si_csf_si",
      "classic_asi_peak_diff",
      "classic_asi_asi",
      "classic_fd_fd"
    ]
  }
}