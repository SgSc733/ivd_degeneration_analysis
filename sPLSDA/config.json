{
  "data": {
    "mode": "dual_csv",
    "unperturbed_csv_path": "raw.csv",
    "perturbed_csv_path": "pert.csv",
    "csv_path": "最终模型输入.csv",
    "id_col": "case_id_层级",
    "label_col": "pfirrmann",
    "classic_prefix": "classic_",
    "patient_id_from_id_col": true,
    "patient_id_sep": "_",
    "level_from_id_col": true,
    "level_sep": "_",
    "segment_levels": ["L3-L4", "L4-L5", "L5-S1"],
    "add_segment_onehot": false,
    "case_meta_onehot": {
      "enabled": false,
      "statistics_csv_path": "statistics.csv",
      "case_id_col": "image_id",
      "columns": ["batch_scanner"],
      "prefix": "meta_",
      "drop_first": false,
      "on_missing": "error"
    },
    "pooling": {
      "stats": ["mean-d"],
      "pyr_prefix": "PyRadiomics_",
      "deep_prefix": "DeepPCA_",
      "tensor_prefix": "TensorPCA_",
      "feature_types": ["classic", "pyr"],
      "out_prefix": "pool_"
    },
    "feature_order": "csv",
    "drop_patterns": [
      "^(?!classic_(?:dhi_dhi|dhi_disc_height|t2si_si_ratio|t2si_roi_si|t2si_csf_si|asi_peak_diff|asi_asi|fd_fd)$).*"
  ],
    "drop_cols": []
  },
  "feature_selection": {
    "enabled": true,
    "statistics_csv_path": "statistics.csv",
    "feature_types": ["classic","pyradiomics","deep","tensor"],
    "enable_pca": true,
    "pca_eta": 0.95,
    "pca_m_cap": 50,
    "icc_threshold": 0.6,
    "alpha_fdr": 0.05,
    "rho_min": 0.0,
    "dup_corr_threshold": 0.95,
    "enable_stability_selection": true,
    "enet_l1_ratio": 0.8,
    "enable_auto_lambda_cv": true,
    "lambda_value": 0.01,
    "lambda_cv_folds": 5,
    "lambda_cv_n_alphas": 100,
    "lambda_cv_epsilon": 0.01,
    "lambda_cv_use_1se": false,
    "enable_lambda_size_tuning": false,
    "bootstrap_B": 50,
    "stability_delta": 0.0001,
    "stability_tau": 0.3,
    "k_max": 120,
    "deep_feature_prefixes": ["Deep_"],
    "tensor_feature_prefixes": ["Tucker_", "Tensor_", "tensor_", "TENSOR_"],
    "force_include_features": [
      "classic_dhi_dhi",
      "classic_dhi_disc_height",
      "classic_t2si_si_ratio",
      "classic_t2si_roi_si",
      "classic_t2si_csf_si",
      "classic_asi_peak_diff",
      "classic_asi_asi",
      "classic_fd_fd"
    ]
  },
  "labels": {
    "xlsx_path": "pfirr_data.xlsx",
    "sheet_name": null,
    "patient_id_col": "序号",
    "level_to_col": {
      "L3-L4": "L34",
      "L4-L5": "L45",
      "L5-S1": "L5S1"
    },
    "on_missing": "error"
  },
  "cv": {
    "n_splits": 5
  },
  "tuning": {
    "enabled": true,
    "inner_n_splits": 3,
    "H_candidates": [2, 3],
    "keepX_candidates": [10, 15, 20, 30, 40, 50],
    "enforce_keepX_monotone": true,
    "version_candidates": ["segment-aligned"],
    "dist_candidates": ["mahalanobis.dist"],
    "alpha_candidates": [0.5, 1, 2, 4],
    "eta_kappa": 3.0,
    "eta_spearman": 1.0,
    "eta_acc_pm1": 0.0,
    "tie_tol": 1e-6
  },
  "training": {
    "seed": 0
  },
  "ordinal": {
    "n_classes": 5,
    "decision_threshold": {
      "default": 0.5
    }
  },
  "preprocess": {
    "rank_gauss": true
  },
  "splsda": {
    "n_components": 2,
    "keepX": [10, 10],
    "eps": 1e-6
  },
  "postprocess": {
    "version": "segment-aligned",
    "dist": "centroids.dist",
    "alpha": 1.0,
    "n_min": 10,
    "cov_reg": 0.7,
    "use_pooled_cov": false,
    "axis_a": [1.0, 0.0]
  },
  "explain": {
    "enabled": true,
    "fold": "best",
    "dpi": 300,
    "only_selected": false,
    "top_k": 20
  },
  "output": {
    "base_dir": "outputs",
    "run_name": null
  }
}
